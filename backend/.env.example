# Copy to .env and adjust. Never commit .env.

# Required for classroom / production: serve React from frontend/dist
NODE_ENV=production

# Listen port (default 3006 if omitted)
PORT=3006

# Use a long random string in production (sessions)
SESSION_SECRET=replace-with-a-long-random-string

# Only if you terminate HTTPS in front of this app (reverse proxy / TLS)
# USE_HTTPS=true
